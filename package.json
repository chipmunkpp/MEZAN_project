{
  "name": "saver98",
  "productName": "Saver 98",
  "version": "0.4.0",
  "description": "Personal Finance Assistant — Windows 98 Style",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "test": "node tests/run-tests.js",
    "build": "electron-builder --win",
    "build:dir": "electron-builder --win --dir",
    "pack": "electron-builder --dir"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "@tesseract.js-data/eng": "^1.0.0",
    "@tesseract.js-data/tha": "^1.0.0",
    "electron-updater": "^6.8.3",
    "tesseract.js": "^7.0.0"
  },
  "build": {
    "appId": "com.saver98.app",
    "productName": "Saver 98",
    "copyright": "Copyright © 2026 Saver 98",
    "directories": {
      "output": "release"
    },
    "files": [
      "index.html",
      "main.js",
      "preload.js",
      "ocr-utils.js",
      "renderer-utils.js",
      "node_modules/tesseract.js/dist/**/*",
      "node_modules/tesseract.js-core/tesseract-core*.js",
      "node_modules/tesseract.js-core/tesseract-core*.wasm",
      "node_modules/@tesseract.js-data/eng/4.0.0/eng.traineddata.gz",
      "node_modules/@tesseract.js-data/tha/4.0.0/tha.traineddata.gz",
      "assets/**/*",
      "!app/**",
      "!out/**",
      "!target/**",
      "!_archive/**",
      "!release/**",
      "!*.jar",
      "!*.bat",
      "!*.xml",
      "!*.iss",
      "!*.exe",
      "!*.ps1",
      "!*.txt",
      "!pom.xml",
      "!data/**",
      "!receipts/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Saver 98",
      "installerHeaderIcon": "assets/icon.ico"
    }
  }
}
